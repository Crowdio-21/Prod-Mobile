<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chaquopy Python Test"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking Python availability..."
        android:textSize="16sp"
        android:background="#F0F0F0"
        android:padding="8dp"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/resultTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test results will appear here..."
            android:textSize="14sp"
            android:background="#FFFFFF"
            android:padding="8dp" />

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnTestBasic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Basic Python Function"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTestNumpy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test NumPy Function"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTestPandas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Pandas Function"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTestSerialized"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Serialized Code"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCheckModules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Available Modules"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</LinearLayout>
