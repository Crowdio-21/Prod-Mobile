<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".ui.WorkerIdTestActivity">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Worker ID Manager Test"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ready to test worker ID functionality"
        android:textSize="16sp"
        android:background="@drawable/rounded_background"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/titleTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/workerIdLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Worker ID:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/statusTextView"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/workerIdTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No worker ID"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:background="@drawable/rounded_background"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/workerIdLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/deviceIdLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device ID:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/workerIdTextView"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/deviceIdTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No device ID"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:background="@drawable/rounded_background"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/deviceIdLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/generatedAtLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Generated At:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/deviceIdTextView"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/generatedAtTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Not generated"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:background="@drawable/rounded_background"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/generatedAtLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/getWorkerIdButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get/Generate Worker ID"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/generatedAtTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/resetWorkerIdButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Reset Worker ID"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/getWorkerIdButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/refreshInfoButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Refresh Info"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/resetWorkerIdButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/testPythonBridgeButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Test Python Bridge"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/refreshInfoButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
